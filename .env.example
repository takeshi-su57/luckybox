# RPC endpoint for balance/send commands
ETH_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Deterministic KDF salt override
BRAIN_WALLET_SALT=brainvault:v1:ethereum

# Supported networks: ethereum, arbitrum, sepolia, base, polygon
VAULT_NETWORK=sepolia
VAULT_NATIVE_TOKEN=ETH

# Optional token symbol map for --token flags (comma-separated SYMBOL:ADDRESS)
# Example Sepolia addresses (replace as needed):
VAULT_ERC20_TOKENS=USDC:0x1c7d4b196cb0c7b01d743fbc6116a902379c7238
