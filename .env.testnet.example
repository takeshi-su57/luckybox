BRAIN_WALLET_SALT=replace-with-test-salt
BRAIN_PASSPHRASE=replace-with-test-passphrase
VAULT_NETWORK=sepolia
ETH_RPC_URL=https://sepolia.infura.io/v3/replace-with-key
VAULT_ERC20_TOKENS=USDT:0x0000000000000000000000000000000000000000

# Safety gates
TEST_ENABLE_E2E=true
TESTNET_ALLOW_VALUE_TRANSFER=false

# External funded account used to seed/reclaim test funds.
TEST_EXTERNAL_PRIVATE_KEY=0xreplace_with_prefunded_private_key
TEST_EXTERNAL_ADDRESS=0xreplace_with_prefunded_address

# Test token and flow amounts.
TEST_TOKEN_SYMBOL=USDT
TEST_ETH_PREFUND=0.01
TEST_USDT_PREFUND=10
TEST_ETH_DISTRIBUTE_EACH=0.002
TEST_ETH_RETURN_EACH=0.001
TEST_USDT_DISTRIBUTE_EACH=2
TEST_USDT_RETURN_EACH=1
TEST_ETH_FINAL_RESERVE=0.0005
